#!/usr/bin/env bash
# Revolutionary .envrc with AI-native optimizations

# Core mise integration
use mise

# Performance optimization: Parallel tool loading
export MISE_JOBS=$(nproc 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo 4)
export MISE_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/mise"

# AI-native development environment
export OPENAI_API_BASE="http://localhost:11434/v1"  # Local AI inference
export ANTHROPIC_API_KEY="$(cat ~/.config/anthropic/api_key 2>/dev/null || echo '')"

# Database optimization for development
export SQLITE_TMPDIR="/tmp/sqlite-${USER}"
export DUCKDB_MEMORY_LIMIT="2GB"
export DUCKDB_THREADS=$(nproc)

# FZF revolutionary configuration
export FZF_DEFAULT_COMMAND='fd --type f --strip-cwd-prefix --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND='fd --type d --strip-cwd-prefix --hidden --follow --exclude .git'
export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border --preview "bat --style=numbers --color=always --line-range :500 {}" --preview-window=right:50%:wrap'

# Development acceleration
export UV_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/uv"
export BUN_INSTALL_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/bun"
export CARGO_HOME="${XDG_DATA_HOME:-$HOME/.local/share}/cargo"

# Security hardening
export HISTFILE="/dev/null"  # Disable history in development containers
export LESSHISTFILE="/dev/null"

# Performance monitoring
export MISE_LOG_LEVEL="warn"
export RUST_LOG="warn"

echo "🚀 Warp Session Suite initialized with AI-native optimizations"
