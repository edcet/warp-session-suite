#!/usr/bin/env bash
# Interactive fuzzy finder for Warp block output navigation.
# Shows list of pane genealogy items, copies pane id JSON on enter.
# Requires warps CLI, jq, fzf, glow

set -euo pipefail

warps preview pane_genealogy --limit 5000 --format json |
  jq -R -s -c 'split("\n")[:-1] | map(fromjson) | .[] | @base64' |
  fzf --ansi \
      --header="[Warp] Jump to block — ENTER copies pane_id to clipboard" \
      --preview 'echo {} | base64 --decode | jq -r "to_entries | map("\(.key): \(.value)") | join("\n")" | glow -' \
      --bind 'enter:execute-silent(echo {} | base64 --decode | jq -r .pane_id | pbcopy)+abort'
